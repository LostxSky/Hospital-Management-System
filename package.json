{
    "name": "hospital-management-system",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "frontend",
        "backend"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
        "start": "concurrently \"npm run start -w backend\" \"npm run dev -w frontend\"",
        "seed": "npm run seed -w backend",
        "install:all": "npm install",
        "postinstall": "npm run seed"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/node": "^24.10.1",
        "concurrently": "^8.2.2",
        "eslint": "^9.39.1",
        "globals": "^16.5.0",
        "nodemon": "^3.1.14",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.48.0"
    }
}
